# agents-hub — config do PROJETO (não-secreto, versionado).
# O CLICKUP_TOKEN NÃO vai aqui — fica só no .env global do agents-hub.
# O REPO_ROOT também não — é injetado pelo `make` (REPO_ROOT=$(CURDIR)).
# Estes valores vencem o .env global (carregados com override).

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=<nome-do-projeto>
# Branch de integração base (de onde saem as branches da sprint e alvo do PR).
# Default: develop. Descomente para usar outra.
# BASE_BRANCH=develop

# Identidade do GitHub CLI (gh) para ESTE projeto. O push usa a chave SSH do remote;
# já o PR/merge usa o TOKEN do gh — se a conta ativa do gh não tiver acesso ao repo da
# org, o `gh pr create` falha no fim da sprint. Aponte para um config isolado do gh
# (não-secreto — é só um caminho) logado na conta certa:
#   GH_CONFIG_DIR=~/.config/gh-hologram   (~ é expandido)
# Cria-se com:  GH_CONFIG_DIR=~/.config/gh-hologram gh auth login
# Vazio = usa o gh default do ambiente. NUNCA ponha GH_TOKEN aqui (é segredo; este
# arquivo é versionado) — para token, use o gh isolado acima.
# GH_CONFIG_DIR=

# Modelo do Claude (opcional; vazio = default do CLI). Global e/ou por papel —
# ex.: um modelo mais forte no QA e mais barato nos executores.
# CLAUDE_MODEL=
# CLAUDE_MODEL_BACKEND=
# CLAUDE_MODEL_FRONTEND=
# CLAUDE_MODEL_QA=
# CLAUDE_MODEL_INFRA=

# ── ClickUp (IDs — não-secretos; preencher) ───────────────────────────────────
# Descubra todos com:  make clickup-ids   (ou o `make init` pergunta interativamente).
# CLICKUP_TEAM_ID = o "Workspace ID" no ClickUp novo (era chamado de "Team ID").
CLICKUP_TEAM_ID=<clickup-team-id>
CLICKUP_LIST_ID=<clickup-list-id>
CLICKUP_DOC_ID=<clickup-doc-id>
# Doc destino do `make context-sync` (decisions/learnings/design-system).
# Vazio = usa o CLICKUP_DOC_ID e cria páginas com prefixo "[CONTEXTO] ".
CLICKUP_CONTEXT_DOC_ID=<clickup-context-doc-id>

# Responsável pelas tasks dos agents (user id do ClickUp do dev deste projeto).
# IMPORTANTE: NÃO depende de quem gerou o CLICKUP_TOKEN — o token pode ser
# compartilhado/admin e nem todo dev tem permissão de gerar um. Defina aqui o id
# da pessoa que deve receber as tasks. Vazio = fallback p/ o dono do token (pode
# atribuir à pessoa ERRADA). Pegue o id com:  make clickup-members
# CLICKUP_ASSIGNEE_ID=

# ── Infra/cloud (opcional — só se houver deploy) ──────────────────────────────
# GCP_PROJECT_ID=
# GCP_REGION=
# GCP_ARTIFACT_REGISTRY=

# ── Contrato backend↔frontend (opcional) ─────────────────────────────────────
# Se o frontend consome um contrato gerado do backend (OpenAPI, GraphQL schema,
# protobuf…), o hub o mantém DETERMINÍSTICO antes do PR: regenera do código,
# commita e propaga ao worktree do frontend, e regenera os tipos/cliente lá.
# Sem isto definido → no-op (projeto sem contrato compartilhado). Exemplo FastAPI:
#   CONTRACT_REGEN_CMD='cd api && .venv/bin/python scripts/dump_openapi.py'  # cwd=worktree backend
#   CONTRACT_ARTIFACTS=api/openapi.json     # rel.; commitado e copiado p/ o frontend (vírgula p/ vários)
#   CONTRACT_TYPES_CMD='cd web && npm run gen:types'                          # cwd=worktree frontend
# CONTRACT_REGEN_CMD=
# CONTRACT_ARTIFACTS=
# CONTRACT_TYPES_CMD=

# ── Gate de testes (opcional) ─────────────────────────────────────────────────
# Bloqueia a integração se a sprint adicionar arquivo-fonte novo (ex.: um endpoint)
# sob TESTGATE_SOURCE sem teste novo/alterado sob TESTGATE_TESTS. Evita feature sem
# cobertura. Sem ambos → no-op. Lista por vírgula/espaço. Exemplo (FastAPI):
#   TESTGATE_SOURCE=api/app/routers/
#   TESTGATE_TESTS=api/tests/
# TESTGATE_SOURCE=
# TESTGATE_TESTS=

# ── Layout do repo (opcional) — caminhos que cada agent COMMITA e o QA faz DIFF ──
# Use se o projeto NÃO for api/+web/. Lista separada por vírgula ou espaço.
# (O escopo de ESCRITA dos agents é separado: settings.local.<role> + AGENT_DENY_PREFIXES.)
# Defaults: backend=api/  frontend=web/ middleware.ts  qa=api/tests/ web/__tests__/
#           infra=api/Dockerfile web/Dockerfile docker-compose.yml .github/ scripts/ .env.example
# A memória (.claude/memory/learnings.md, decisions.md) é sempre incluída no QA.
# Layout monorepo deste projeto: apps/api/ (backend) + apps/web/ (frontend).
# Sem estes, o hub usaria os defaults api/ e web/ (que NÃO existem aqui) e commitaria vazio.
AGENT_PATHS_BACKEND=apps/api/
AGENT_PATHS_FRONTEND=apps/web/
AGENT_PATHS_QA=apps/api/tests/ apps/web/src/
AGENT_PATHS_INFRA=docker/ .github/ scripts/ .env.example apps/api/.env.example apps/web/.env.example

# ── Chaves novas do template (anexadas por 'make init') ──
# GH_LOGIN=
# GCLOUD_ACCOUNT=              # ex.: voce@empresa.com  (gcloud config get-value account)
# GCLOUD_PROJECT=              # ex.: meu-projeto-gcp   (gcloud config get-value project)
# CLOUDSDK_ACTIVE_CONFIG_NAME=
