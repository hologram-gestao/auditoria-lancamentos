# Normaliza line endings para LF em todos os arquivos de texto
* text=auto eol=lf

# Binários
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.zip binary
*.gz binary

# Shell scripts sempre LF
*.sh text eol=lf

# Batch/PS scripts no Windows — CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
