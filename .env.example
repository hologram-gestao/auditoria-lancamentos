# ============================================================
# .env.example — copie para .env e ajuste os valores
# Este arquivo NÃO contém segredos reais.
#
# Variáveis globais do docker-compose. Cada app também tem seu
# próprio .env.example em apps/api e apps/web.
#
# IMPORTANTE: pydantic-settings (backend) não trata `#` como comentário
# inline em .env. Mantenha comentários em linhas separadas.
# ============================================================

# Ambiente: development | staging | production
ENVIRONMENT=development
# Log level: debug | info | warning | error
LOG_LEVEL=debug

# ---------- PostgreSQL ----------
POSTGRES_USER=auditoria
POSTGRES_PASSWORD=change_me_in_dev_only
POSTGRES_DB=auditoria_dev
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Portas dos apps ----------
API_PORT=8000
WEB_PORT=3000
