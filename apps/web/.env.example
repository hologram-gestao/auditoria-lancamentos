# ============================================================
# apps/web/.env.example — copie para apps/web/.env.local
# ============================================================

# URL interna da API — só usada server-side pelo Next pra reverse-proxy
# das chamadas /api/v1/* (rewrites em next.config.mjs). Browser fala SEMPRE
# com o próprio Next em /api/v1/* (mesma origem) e nunca toca essa URL.
# Quando rodando no Docker Compose: http://api:8000
INTERNAL_API_URL=http://localhost:8000

# Ambiente
NEXT_PUBLIC_ENVIRONMENT=development

# Sentry (opcional em dev)
NEXT_PUBLIC_SENTRY_DSN=

# S15 Fase 2 — Criar tipos de anomalia customizados (admin UI).
# Default false enquanto o catálogo do seed não é validado em produção.
NEXT_PUBLIC_ANOMALY_TYPE_CREATE_ENABLED=false
