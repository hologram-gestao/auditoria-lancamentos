# ============================================================
# apps/api/.env.example — copie para apps/api/.env
# NUNCA commitar o .env real.
#
# IMPORTANTE: pydantic-settings NÃO trata `#` como comentário inline.
# Os comentários DEVEM ficar em linha separada (como neste arquivo).
# ============================================================

# Ambiente: development | staging | production
ENVIRONMENT=development
# Log level: debug | info | warning | error
LOG_LEVEL=debug

# ---------- Banco ----------
# Use o host "postgres" quando rodar dentro do docker-compose;
# "localhost" quando rodar a API fora do container (make dev-api).
DATABASE_URL=postgresql+psycopg://auditoria:change_me_in_dev_only@localhost:5432/auditoria_dev

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
# Backend do cache L2: memory | redis
CACHE_BACKEND=memory

# ---------- Segurança ----------
# Gere com: openssl rand -hex 32  (ou `make gen-key` na raiz)
OMIE_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
# Blind index do filtro `search` na Tela de Revisão (S16). NÃO reusar
# OMIE_ENCRYPTION_KEY — separação de domínios cripto. Gere com
# `openssl rand -hex 32` e mantenha por instância (rotação requer rebuild
# do índice; em prod só rotacionar com plano de backfill).
SEARCH_BLIND_INDEX_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# ---------- Cookies ----------
# true em produção (HTTPS); false em dev local sem TLS
COOKIE_SECURE=false
# Vazio em dev (mesma origem); em prod definir o domain ex: ".hologram.com.br"
COOKIE_DOMAIN=
# lax | strict | none
COOKIE_SAMESITE=lax

# ---------- CORS ----------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---------- Hosts confiáveis ----------
# CSV de hostnames aceitos no header Host (TrustedHostMiddleware).
# Em prod, settar com o(s) FQDN(s) público(s) — protege contra host header
# injection. Em dev/test, `test` e `testserver` são necessários (httpx).
ALLOWED_HOSTS=localhost,127.0.0.1,test,testserver

# ---------- Integrações externas ----------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5
ANTHROPIC_MODEL_FALLBACK=claude-opus-4-6
# Timeout total da chamada à API da Anthropic (segundos). Padrão 60.
ANTHROPIC_TIMEOUT_SECONDS=60

OMIE_BASE_URL=https://app.omie.com.br/api/v1
OMIE_TIMEOUT_SECONDS=15
# `ListarExtrato` não pagina — extratos grandes podem demorar. Job ARQ
# tolera espera maior, então mantemos um timeout próprio mais folgado.
OMIE_TIMEOUT_EXTRATO_SECONDS=60

# ---------- Limites ----------
MAX_UPLOAD_SIZE_MB=20
PARSE_TIMEOUT_SECONDS=60

# ---------- Qualificação (S19 BACK 12.1) ----------
# Ativa a análise de qualificação (IA + histórico + outlier) no
# pipeline. Default true. Setar false desliga a camada sem afetar o
# matching base — útil se a Anthropic ficar fora ou pra cortar custo.
QUALIFICATION_ENABLED=true

# ---------- Observabilidade ----------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
