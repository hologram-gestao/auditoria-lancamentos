# ============================================================
# apps/api/.env.example — copie para apps/api/.env
# NUNCA commitar o .env real.
#
# IMPORTANTE: pydantic-settings NÃO trata `#` como comentário inline.
# Os comentários DEVEM ficar em linha separada (como neste arquivo).
# ============================================================

# Ambiente: development | staging | production
ENVIRONMENT=development
# Log level: debug | info | warning | error
LOG_LEVEL=debug

# ---------- Banco ----------
# Use o host "postgres" quando rodar dentro do docker-compose;
# "localhost" quando rodar a API fora do container (make dev-api).
DATABASE_URL=postgresql+psycopg://auditoria:change_me_in_dev_only@localhost:5432/auditoria_dev

# ---------- Segurança ----------
# Gere com: openssl rand -hex 32  (ou `make gen-key` na raiz)
OMIE_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
# Blind index do filtro `search` na Tela de Revisão (S16). NÃO reusar
# OMIE_ENCRYPTION_KEY — separação de domínios cripto. Gere com
# `openssl rand -hex 32` e mantenha por instância (rotação requer rebuild
# do índice; em prod só rotacionar com plano de backfill).
SEARCH_BLIND_INDEX_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_COST=12

# ---------- Cookies ----------
# true em produção (HTTPS); false em dev local sem TLS
COOKIE_SECURE=false
# Vazio em dev (mesma origem); em prod definir o domain ex: ".hologram.com.br"
COOKIE_DOMAIN=
# lax | strict | none
COOKIE_SAMESITE=lax

# ---------- CORS ----------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---------- Hosts confiáveis ----------
# CSV de hostnames aceitos no header Host (TrustedHostMiddleware).
# Em prod, settar com o(s) FQDN(s) público(s) — protege contra host header
# injection. Em dev/test, `test` e `testserver` são necessários (httpx).
ALLOWED_HOSTS=localhost,127.0.0.1,test,testserver

# ---------- Integrações externas ----------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5
ANTHROPIC_MODEL_FALLBACK=claude-opus-4-6
# Timeout total da chamada à API da Anthropic (segundos). Padrão 150 — extratos
# reais grandes (ex.: 143 transações) levam ~75s na extração e estouravam o 60s
# antigo, devolvendo 504.
# ACOPLAMENTO: o proxy do BFF (`experimental.proxyTimeout` em
# apps/web/next.config.mjs) precisa ficar ACIMA deste valor (160s). Se o BFF
# cortar antes, o usuário vê um 500 genérico mesmo com o backend respondendo.
ANTHROPIC_TIMEOUT_SECONDS=150
# Teto de tokens de SAÍDA do parsing (BACK 02.1). Inteiro comum, nunca segredo.
# Validado na subida contra o cap de saída do modelo: um valor acima do que a
# Anthropic aceita impede o serviço de iniciar (em vez de virar 400 em runtime).
ADL_PARSE_MAX_OUTPUT_TOKENS=32768

OMIE_BASE_URL=https://app.omie.com.br/api/v1
OMIE_TIMEOUT_SECONDS=15
# `ListarExtrato` não pagina — extratos grandes podem demorar. O processamento
# em background tolera espera maior, então mantemos um timeout próprio folgado.
OMIE_TIMEOUT_EXTRATO_SECONDS=60

# ---------- Limites ----------
MAX_UPLOAD_SIZE_MB=20
PARSE_TIMEOUT_SECONDS=60
# Teto do processamento async da conciliação (Omie + matching + qualificação),
# rodando via BackgroundTasks. Substitui o antigo job_timeout do ARQ.
RECONCILIATION_TIMEOUT_SECONDS=900

# ---------- Qualificação (S19 BACK 12.1) ----------
# Ativa a análise de qualificação (IA + histórico + outlier) no
# pipeline. Default true. Setar false desliga a camada sem afetar o
# matching base — útil se a Anthropic ficar fora ou pra cortar custo.
QUALIFICATION_ENABLED=true

# ---------- Observabilidade ----------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- Envelope encryption / KMS (Sprint 3, BACK 03.3) ----------
# Recurso KEK no Cloud KMS. Setado em prod → wrap/unwrap da DEK-por-cliente no
# KMS (a KEK nunca sai de lá). Vazio → wrapper LOCAL (dev/test), KEK derivada de
# OMIE_ENCRYPTION_KEY. NÃO é segredo — é um resource path público.
# Provisionado por `scripts/setup-gcp.sh <env>` e injetado nos deploys
# (serviço da API + job de migração). Ex.:
# projects/liberdade-assessoria/locations/southamerica-east1/keyRings/adl/cryptoKeys/kek
KEK_KMS_KEY_NAME=
# key_id gravado no envelope (v<n>:<key_id>:...). Uma por era de chave.
KEK_KEY_ID=k1

# ---------- Alerting (Sprint 3, BACK 03.6) — FAIL-CLOSED em prod/staging ----------
# Destino do alerta de plantão. SEMPRE endereço COMPARTILHADO da equipe (nunca
# pessoa). Em staging/production o serviço NÃO SOBE sem ao menos um canal
# ENTREGÁVEL (webhook OU email+smtp). Em dev, roda com warning.
# Em prod os valores vêm do Secret Manager (alert-webhook-url-<env> /
# alert-email-to-<env>), montados pelos workflows de deploy no serviço da API E
# nos jobs (paridade). Lidos com .strip() (Secret Manager via echo deixa \n).
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
# E-mail só é entregável com transporte SMTP configurado:
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=adl-alertas@hologram.com.br
ALERT_WEBHOOK_TIMEOUT_SECONDS=5.0
