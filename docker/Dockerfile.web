# syntax=docker/dockerfile:1.7

# ============================================================
# Stage 1 — deps (instala dependências do monorepo via pnpm)
# ============================================================
FROM node:20-alpine AS deps

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /workspace

# Copia manifestos do monorepo para aproveitar cache
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json apps/web/
COPY packages/shared-types/package.json packages/shared-types/

RUN pnpm install --frozen-lockfile || pnpm install

# ============================================================
# Stage 2 — build
# ============================================================
FROM node:20-alpine AS builder

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /workspace

COPY --from=deps /workspace/node_modules ./node_modules
COPY --from=deps /workspace/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /workspace/packages/shared-types/node_modules ./packages/shared-types/node_modules

# Código
COPY . .

# Browser chama `/api/v1/*` (mesma origem) e Next reverse-proxia pra
# `INTERNAL_API_URL` server-side (ver `next.config.mjs rewrites`).
# Tem que vir como build-arg porque o Next 14 resolve `process.env` em
# rewrites durante o `next build` — runtime env var não funciona aqui
# (cai pro fallback localhost).
# Default casa com dev local. Em prod, CI passa `--build-arg`.
ARG INTERNAL_API_URL=http://localhost:8000
ENV INTERNAL_API_URL=${INTERNAL_API_URL}

ENV NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter @auditoria/web build

# ============================================================
# Stage 3 — runtime
# ============================================================
FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=8080 \
    HOSTNAME=0.0.0.0

RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

# Aproveita o output standalone do Next.js (next.config.mjs:43)
COPY --from=builder --chown=nextjs:nodejs /workspace/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /workspace/apps/web/.next/static ./apps/web/.next/static
# Nota: apps/web/public/ NÃO existe no projeto (sem static assets).
# Se um dia adicionar (ex: favicon, imagens), descomenta a linha abaixo:
# COPY --from=builder --chown=nextjs:nodejs /workspace/apps/web/public ./apps/web/public

USER nextjs

# Cloud Run injeta PORT=8080 por default — alinhamento com a API.
EXPOSE 8080

# wget usa shell form (sem []) — `${PORT}` expande no /bin/sh. Usar 127.0.0.1
# em vez de `localhost` porque Alpine resolve `localhost` pra IPv6 (`::1`)
# primeiro, e Next.js só binda em IPv4 (`0.0.0.0`).
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --quiet --tries=1 --spider "http://127.0.0.1:${PORT:-8080}/" || exit 1

# Exec form: `node` vira PID 1 direto — SIGTERM do Cloud Run vai direto pro
# server.js. Next.js standalone server lê `PORT` da env automaticamente.
CMD ["node", "apps/web/server.js"]
